{
  "motion": {
    "tap": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.fast}",
        "timingFunction": "{easing.standard}",
        "delay": "0ms"
      }
    },
    "toggle": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.medium}",
        "timingFunction": "{easing.standard}",
        "delay": "0ms"
      }
    },
    "transition": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.normal}",
        "timingFunction": "{easing.standard}",
        "delay": "0ms"
      }
    },
    "nav": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.nav}",
        "timingFunction": "{easing.standard}",
        "delay": "0ms"
      }
    },
    "enter": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.enter}",
        "timingFunction": "{easing.spring}",
        "delay": "0ms"
      }
    },
    "sheet": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.slow}",
        "timingFunction": "{easing.standard}",
        "delay": "0ms"
      }
    },
    "spring": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.fast}",
        "timingFunction": "{easing.spring}",
        "delay": "0ms"
      }
    },
    "blob": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.blob}",
        "timingFunction": "{easing.spring}",
        "delay": "0ms"
      }
    }
  }
}