{
  "color": {
    "bg": {
      "canvas":   { "$value": "{color.oat.900}", "$type": "color" },
      "surface":  { "$value": "{color.oat.800}", "$type": "color" },
      "elevated": { "$value": "{color.oat.700}", "$type": "color" }
    },
    "text": {
      "primary":   { "$value": "{color.ink.50}",         "$type": "color" },
      "secondary": { "$value": "{color.ink.100}",        "$type": "color" },
      "tertiary":  { "$value": "{color.ink.500}",        "$type": "color" },
      "inverse":   { "$value": "{color.ink.900}",        "$type": "color" },
      "brand":     { "$value": "{color.terracotta.300}", "$type": "color" },
      "onBrand":   { "$value": "{color.oat.50}",         "$type": "color" }
    },
    "border": {
      "subtle": { "$value": "{color.alpha.bone.08}",  "$type": "color" },
      "strong": { "$value": "{color.alpha.bone.15}",  "$type": "color" },
      "focus":  { "$value": "{color.terracotta.300}", "$type": "color" }
    },
    "brand": {
      "default": { "$value": "{color.terracotta.300}", "$type": "color" },
      "deep":    { "$value": "{color.amber.300}",      "$type": "color" }
    },
    "accent": {
      "calm": { "$value": "{color.sage.300}", "$type": "color" },
      "soft": { "$value": "{color.dust.300}", "$type": "color" }
    },
    "feedback": {
      "warn": { "$value": "{color.warn.300}", "$type": "color" }
    },
    "mood": {
      "low":    { "fill": { "$value": "{color.mood.low.color}",    "$type": "color" }, "dot": { "$value": "{color.mood.low.dot}",    "$type": "color" } },
      "flat":   { "fill": { "$value": "{color.mood.flat.color}",   "$type": "color" }, "dot": { "$value": "{color.mood.flat.dot}",   "$type": "color" } },
      "ok":     { "fill": { "$value": "{color.mood.ok.color}",     "$type": "color" }, "dot": { "$value": "{color.mood.ok.dot}",     "$type": "color" } },
      "bright": { "fill": { "$value": "{color.mood.bright.color}", "$type": "color" }, "dot": { "$value": "{color.mood.bright.dot}", "$type": "color" } },
      "warm":   { "fill": { "$value": "{color.mood.warm.color}",   "$type": "color" }, "dot": { "$value": "{color.mood.warm.dot}",   "$type": "color" } }
    }
  },
  "spacing": {
    "screen":  { "x":       { "$value": "{space.10}",      "$type": "dimension" }, "safeTop": { "$value": "{space.safeTop}", "$type": "dimension" } },
    "card":    { "padding": { "$value": "{space.9}",       "$type": "dimension" }, "compact": { "$value": "{space.8}",       "$type": "dimension" }, "tight": { "$value": "{space.6}", "$type": "dimension" } },
    "section": { "gap":     { "$value": "{space.11}",      "$type": "dimension" }, "margin":  { "$value": "{space.10}",      "$type": "dimension" } },
    "grid":    { "gap":     { "$value": "{space.5}",       "$type": "dimension" } },
    "chip":    { "gap":     { "$value": "{space.3}",       "$type": "dimension" } },
    "heatmap": { "gap":     { "$value": "{space.2}",       "$type": "dimension" } }
  },
  "radius": {
    "button":    { "$value": "{radius.lg}",   "$type": "dimension" },
    "card":      { "$value": "{radius.3xl}",  "$type": "dimension" },
    "segmented": { "$value": "{radius.sm}",   "$type": "dimension" },
    "sheet":     { "$value": "{radius.2xl}",  "$type": "dimension" },
    "pill":      { "$value": "{radius.full}", "$type": "dimension" }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": { "fontFamily": "{fontFamily.serif}", "fontSize": "{fontSize.56}", "fontWeight": "{fontWeight.medium}", "lineHeight": "{lineHeight.tight}" }
    },
    "heading": {
      "1": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.serif}", "fontSize": "{fontSize.42}", "fontWeight": "{fontWeight.medium}", "lineHeight": "{lineHeight.tight}" } },
      "2": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.serif}", "fontSize": "{fontSize.36}", "fontWeight": "{fontWeight.medium}", "lineHeight": "{lineHeight.tight}" } },
      "3": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.serif}", "fontSize": "{fontSize.30}", "fontWeight": "{fontWeight.medium}", "lineHeight": "{lineHeight.tight}" } },
      "4": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.serif}", "fontSize": "{fontSize.26}", "fontWeight": "{fontWeight.medium}", "lineHeight": "{lineHeight.tight}" } },
      "5": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.serif}", "fontSize": "{fontSize.22}", "fontWeight": "{fontWeight.medium}", "lineHeight": "{lineHeight.snug}" } },
      "6": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.serif}", "fontSize": "{fontSize.18}", "fontWeight": "{fontWeight.medium}", "lineHeight": "{lineHeight.normal}" } }
    },
    "text": {
      "lg": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.15}", "fontWeight": "{fontWeight.regular}", "lineHeight": "{lineHeight.loose}" } },
      "md": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.14}", "fontWeight": "{fontWeight.regular}", "lineHeight": "{lineHeight.loose}" } },
      "rg": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.13}", "fontWeight": "{fontWeight.regular}", "lineHeight": "{lineHeight.relaxed}" } },
      "sm": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.12}", "fontWeight": "{fontWeight.regular}", "lineHeight": "{lineHeight.relaxed}" } },
      "xs": { "$type": "typography", "$value": { "fontFamily": "{fontFamily.sans}", "fontSize": "{fontSize.11}", "fontWeight": "{fontWeight.regular}", "lineHeight": "{lineHeight.normal}" } }
    }
  }
}
