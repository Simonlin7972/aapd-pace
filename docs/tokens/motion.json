{
  "primitive": {
    "duration": {
      "micro":   { "$value": "120ms",  "$type": "duration" },
      "fast":    { "$value": "180ms",  "$type": "duration" },
      "quick":   { "$value": "200ms",  "$type": "duration" },
      "normal":  { "$value": "220ms",  "$type": "duration" },
      "medium":  { "$value": "280ms",  "$type": "duration" },
      "slow":    { "$value": "320ms",  "$type": "duration" },
      "nav":     { "$value": "380ms",  "$type": "duration" },
      "enter":   { "$value": "420ms",  "$type": "duration" },
      "fadeOut": { "$value": "900ms",  "$type": "duration" },
      "blob":    { "$value": "1400ms", "$type": "duration" }
    },
    "easing": {
      "standard": { "$value": [0.32, 0.72, 0, 1],    "$type": "cubicBezier" },
      "spring":   { "$value": [0.34, 1.56, 0.64, 1], "$type": "cubicBezier" }
    }
  },

  "semantic": {
    "motion": {
      "tap":        { "$type": "transition", "$value": { "duration": "{primitive.duration.fast}",   "timingFunction": "{primitive.easing.standard}", "delay": "0ms" } },
      "toggle":     { "$type": "transition", "$value": { "duration": "{primitive.duration.medium}", "timingFunction": "{primitive.easing.standard}", "delay": "0ms" } },
      "transition": { "$type": "transition", "$value": { "duration": "{primitive.duration.normal}", "timingFunction": "{primitive.easing.standard}", "delay": "0ms" } },
      "nav":        { "$type": "transition", "$value": { "duration": "{primitive.duration.nav}",    "timingFunction": "{primitive.easing.standard}", "delay": "0ms" } },
      "enter":      { "$type": "transition", "$value": { "duration": "{primitive.duration.enter}",  "timingFunction": "{primitive.easing.spring}",   "delay": "0ms" } },
      "sheet":      { "$type": "transition", "$value": { "duration": "{primitive.duration.slow}",   "timingFunction": "{primitive.easing.standard}", "delay": "0ms" } },
      "spring":     { "$type": "transition", "$value": { "duration": "{primitive.duration.fast}",   "timingFunction": "{primitive.easing.spring}",   "delay": "0ms" } },
      "blob":       { "$type": "transition", "$value": { "duration": "{primitive.duration.blob}",   "timingFunction": "{primitive.easing.spring}",   "delay": "0ms" } }
    }
  }
}
