{
  "primitive": {
    "space": {
      "0":  { "$value": "0px",  "$type": "dimension" },
      "1":  { "$value": "4px",  "$type": "dimension" },
      "2":  { "$value": "6px",  "$type": "dimension" },
      "3":  { "$value": "8px",  "$type": "dimension" },
      "4":  { "$value": "10px", "$type": "dimension" },
      "5":  { "$value": "12px", "$type": "dimension" },
      "6":  { "$value": "14px", "$type": "dimension" },
      "7":  { "$value": "16px", "$type": "dimension" },
      "8":  { "$value": "18px", "$type": "dimension" },
      "9":  { "$value": "20px", "$type": "dimension" },
      "10": { "$value": "24px", "$type": "dimension" },
      "11": { "$value": "28px", "$type": "dimension" },
      "12": { "$value": "32px", "$type": "dimension" },
      "14": { "$value": "48px", "$type": "dimension" },
      "safeTop": { "$value": "56px", "$type": "dimension" }
    }
  },

  "semantic": {
    "spacing": {
      "screen": {
        "x":       { "$value": "{primitive.space.10}",      "$type": "dimension" },
        "safeTop": { "$value": "{primitive.space.safeTop}", "$type": "dimension" }
      },
      "card": {
        "padding": { "$value": "{primitive.space.9}", "$type": "dimension" },
        "compact": { "$value": "{primitive.space.8}", "$type": "dimension" },
        "tight":   { "$value": "{primitive.space.6}", "$type": "dimension" }
      },
      "section": {
        "gap":    { "$value": "{primitive.space.11}", "$type": "dimension" },
        "margin": { "$value": "{primitive.space.10}", "$type": "dimension" }
      },
      "grid":    { "gap": { "$value": "{primitive.space.5}", "$type": "dimension" } },
      "chip":    { "gap": { "$value": "{primitive.space.3}", "$type": "dimension" } },
      "heatmap": { "gap": { "$value": "{primitive.space.2}", "$type": "dimension" } }
    }
  }
}
