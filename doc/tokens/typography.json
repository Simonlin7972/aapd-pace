{
  "primitive": {
    "fontFamily": {
      "serif": {
        "$value": ["Noto Serif TC", "Source Serif", "Georgia", "PingFang TC", "serif"],
        "$type": "fontFamily"
      },
      "sans": {
        "$value": ["Noto Sans TC", "-apple-system", "system-ui", "PingFang TC", "sans-serif"],
        "$type": "fontFamily"
      },
      "mono": {
        "$value": ["SF Mono", "Roboto Mono", "ui-monospace", "monospace"],
        "$type": "fontFamily"
      }
    },
    "fontWeight": {
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 590, "$type": "fontWeight" }
    },
    "fontSize": {
      "10": { "$value": "10px", "$type": "dimension" },
      "11": { "$value": "11px", "$type": "dimension" },
      "12": { "$value": "12px", "$type": "dimension" },
      "13": { "$value": "13px", "$type": "dimension" },
      "14": { "$value": "14px", "$type": "dimension" },
      "15": { "$value": "15px", "$type": "dimension" },
      "18": { "$value": "18px", "$type": "dimension" },
      "22": { "$value": "22px", "$type": "dimension" },
      "26": { "$value": "26px", "$type": "dimension" },
      "28": { "$value": "28px", "$type": "dimension" },
      "30": { "$value": "30px", "$type": "dimension" },
      "36": { "$value": "36px", "$type": "dimension" },
      "42": { "$value": "42px", "$type": "dimension" },
      "56": { "$value": "56px", "$type": "dimension" },
      "64": { "$value": "64px", "$type": "dimension" }
    },
    "lineHeight": {
      "tight":   { "$value": 1.1,  "$type": "number" },
      "snug":    { "$value": 1.2,  "$type": "number" },
      "display": { "$value": 1.25, "$type": "number" },
      "heading": { "$value": 1.3,  "$type": "number" },
      "card":    { "$value": 1.35, "$type": "number" },
      "label":   { "$value": 1.4,  "$type": "number" },
      "caption": { "$value": 1.5,  "$type": "number" },
      "body":    { "$value": 1.6,  "$type": "number" }
    }
  },

  "semantic": {
    "text": {
      "displayLarge": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.serif}",
          "fontSize":   "{primitive.fontSize.64}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.tight}"
        }
      },
      "displayApp": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.serif}",
          "fontSize":   "{primitive.fontSize.56}",
          "fontWeight": "{primitive.fontWeight.medium}",
          "lineHeight": "{primitive.lineHeight.tight}"
        }
      },
      "editorial": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.serif}",
          "fontSize":   "{primitive.fontSize.42}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.snug}"
        }
      },
      "profileName": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.serif}",
          "fontSize":   "{primitive.fontSize.36}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.snug}"
        }
      },
      "pageTitle": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.serif}",
          "fontSize":   "{primitive.fontSize.30}",
          "fontWeight": "{primitive.fontWeight.medium}",
          "lineHeight": "{primitive.lineHeight.display}"
        }
      },
      "screenTitle": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.serif}",
          "fontSize":   "{primitive.fontSize.28}",
          "fontWeight": "{primitive.fontWeight.medium}",
          "lineHeight": "{primitive.lineHeight.heading}"
        }
      },
      "sectionTitle": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.serif}",
          "fontSize":   "{primitive.fontSize.26}",
          "fontWeight": "{primitive.fontWeight.medium}",
          "lineHeight": "{primitive.lineHeight.heading}"
        }
      },
      "cardTitle": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.serif}",
          "fontSize":   "{primitive.fontSize.22}",
          "fontWeight": "{primitive.fontWeight.medium}",
          "lineHeight": "{primitive.lineHeight.card}"
        }
      },
      "subtitle": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.serif}",
          "fontSize":   "{primitive.fontSize.18}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.caption}"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.sans}",
          "fontSize":   "{primitive.fontSize.15}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.body}"
        }
      },
      "bodySmall": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.sans}",
          "fontSize":   "{primitive.fontSize.14}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.body}"
        }
      },
      "caption": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.sans}",
          "fontSize":   "{primitive.fontSize.13}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.caption}"
        }
      },
      "label": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.sans}",
          "fontSize":   "{primitive.fontSize.12}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.label}"
        }
      },
      "microLabel": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.sans}",
          "fontSize":   "{primitive.fontSize.11}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.label}"
        }
      },
      "tiny": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{primitive.fontFamily.sans}",
          "fontSize":   "{primitive.fontSize.10}",
          "fontWeight": "{primitive.fontWeight.regular}",
          "lineHeight": "{primitive.lineHeight.heading}"
        }
      }
    }
  }
}
